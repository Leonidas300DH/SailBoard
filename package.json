{
  "name": "sailboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "node --env-file=.env.local node_modules/drizzle-kit/bin.cjs migrate",
    "db:import:wdt-2026": "node --env-file=.env.local scripts/import-wdt-2026.mjs",
    "auth:migrate": "npx auth@latest migrate --config lib/auth-server.ts --yes"
  },
  "dependencies": {
    "better-auth": "^1.4.18",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.25.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "22.19.19",
    "@types/pg": "^8.15.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "type": "module"
}
